# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (optional - for GitHub authentication)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (optional - for Google authentication)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email/Password Authentication (optional - for credentials authentication)
# Configure your backend API endpoint for email/password authentication

# AI Assistant Configuration
# OpenAI API Key for AI-powered task configuration assistant
# Generate at: https://platform.openai.com/api/keys
NEXT_PUBLIC_OPENAI_API_KEY=sk_your_actual_api_key_here

# OpenAI Model Selection (optional - default: gpt-4-turbo-preview)
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
NEXT_PUBLIC_OPENAI_MODEL=gpt-4-turbo-preview

# Response Creativity Level (optional - default: 0.7, range: 0-2)
# Lower = more deterministic, Higher = more creative
NEXT_PUBLIC_OPENAI_TEMPERATURE=0.7

# Maximum Tokens Per Response (optional - default: 2000)
# Controls response length and cost
NEXT_PUBLIC_OPENAI_MAX_TOKENS=2000

# Debug Mode (optional - default: false)
# Enable detailed logging for AI interactions
NEXT_PUBLIC_AI_DEBUG=false
