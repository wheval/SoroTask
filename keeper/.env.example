# Soroban Network Configuration
SOROBAN_RPC_URL=https://rpc-futurenet.stellar.org
NETWORK_PASSPHRASE=Test SDF Future Network ; October 2022

# Keeper Account
KEEPER_SECRET=S...

# SoroTask Contract
CONTRACT_ID=C...

# Polling Configuration
POLLING_INTERVAL_MS=10000
MAX_CONCURRENT_READS=10
MAX_CONCURRENT_EXECUTIONS=3
METRICS_PORT=3000
HEALTH_STALE_THRESHOLD_MS=60000

# Keeper Admin API
# Required to use /admin/keeper endpoints
# KEEPER_ADMIN_TOKEN=replace-with-strong-random-token

# Work partitioning / sharding
KEEPER_SHARD_INDEX=0
KEEPER_SHARD_COUNT=1
# Optional human-readable shard label for logs/metrics
# KEEPER_SHARD_LABEL=keeper-a

# P2P keeper discovery and load sharing
# Disabled by default. When enabled, all P2P messages are HMAC-signed.
P2P_ENABLED=false
# Use a strong shared secret distributed out-of-band to trusted keepers only.
# P2P_SHARED_SECRET=replace-with-strong-random-secret
# Optional stable node ID. Defaults to the keeper public key.
# P2P_NODE_ID=keeper-a
# Public URL other keepers can dial, for example http://keeper-a.example.com:4100
# P2P_PUBLIC_URL=http://127.0.0.1:4100
P2P_LISTEN_HOST=0.0.0.0
P2P_LISTEN_PORT=4100
# Comma-separated peer URLs used only for initial discovery; peers gossip the rest.
# P2P_BOOTSTRAP_PEERS=http://keeper-b.example.com:4100,http://keeper-c.example.com:4100
P2P_HEARTBEAT_INTERVAL_MS=10000
P2P_STALE_PEER_MS=45000
P2P_AUTH_WINDOW_MS=30000
P2P_CONNECT_TIMEOUT_MS=5000

# Recurring execution drift detection thresholds (seconds)
DRIFT_WARNING_SECONDS=60
DRIFT_CRITICAL_SECONDS=300

# Task Registry Configuration
# Ledger to start scanning TaskRegistered events from (0 = auto-detect)
START_LEDGER=0

# Execution Configuration
WAIT_FOR_CONFIRMATION=true

# Retry Configuration
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000
MAX_RETRY_DELAY_MS=30000

# Persistent Retry Scheduler Configuration
RETRY_RETENTION_DAYS=7
RETRY_STORAGE_PATH=./data/retries.json
MAX_RETRY_QUEUE_SIZE=100
MAX_RETRIES_PER_CYCLE=2

# Simulation Cache Configuration
SIMULATION_CACHE_TTL=30
SIMULATION_CACHE_MAX_SIZE=1000

# Serverless resolver execution
# Optional JSON file mapping on-chain resolver IDs to sandboxed JS/WASM functions
# RESOLVER_FUNCTIONS_CONFIG=./resolvers.json
RESOLVER_DEFAULT_TIMEOUT_MS=250
# skip = fail closed, allow = fail open after resolver errors
RESOLVER_FAILURE_MODE=skip

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=production

KEEPER_ADMIN_TOKEN=change_me_securely
