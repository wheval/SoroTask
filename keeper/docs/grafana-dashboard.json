{
  "dashboard": {
    "title": "SoroTask Keeper Monitoring",
    "tags": ["sorotask", "keeper", "stellar"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Task Execution Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(keeper_tasks_executed_total[5m])",
            "legendFormat": "Executed"
          },
          {
            "expr": "rate(keeper_tasks_failed_total[5m])",
            "legendFormat": "Failed"
          }
        ],
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
      },
      {
        "id": 2,
        "title": "Task Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "100 * (rate(keeper_tasks_executed_total[5m]) / (rate(keeper_tasks_executed_total[5m]) + rate(keeper_tasks_failed_total[5m])))",
            "legendFormat": "Success %"
          }
        ],
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 }
      },
      {
        "id": 3,
        "title": "Service Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "keeper_uptime_seconds",
            "legendFormat": "Uptime"
          }
        ],
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 }
      },
      {
        "id": 4,
        "title": "Average Fee Paid (XLM)",
        "type": "graph",
        "targets": [
          {
            "expr": "keeper_avg_fee_paid_xlm",
            "legendFormat": "Avg Fee"
          }
        ],
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
      },
      {
        "id": 5,
        "title": "Polling Cycle Duration",
        "type": "graph",
        "targets": [
          {
            "expr": "keeper_last_cycle_duration_ms",
            "legendFormat": "Duration (ms)"
          }
        ],
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
      },
      {
        "id": 6,
        "title": "Low Gas Tasks",
        "type": "stat",
        "targets": [
          {
            "expr": "keeper_low_gas_count",
            "legendFormat": "Low Gas"
          }
        ],
        "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 }
      },
      {
        "id": 7,
        "title": "RPC Connection Status",
        "type": "stat",
        "targets": [
          {
            "expr": "keeper_rpc_connected",
            "legendFormat": "Connected"
          }
        ],
        "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 }
      },
      {
        "id": 8,
        "title": "Total Tasks Checked",
        "type": "stat",
        "targets": [
          {
            "expr": "keeper_tasks_checked_total",
            "legendFormat": "Checked"
          }
        ],
        "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 }
      },
      {
        "id": 9,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "RSS"
          }
        ],
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 }
      },
       {
         "id": 10,
         "title": "Event Loop Lag",
         "type": "graph",
         "targets": [
           {
             "expr": "nodejs_eventloop_lag_seconds",
             "legendFormat": "Lag (s)"
           }
         ],
         "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 }
       },
       {
         "id": 11,
         "title": "Poll Freshness SLO Rate",
         "type": "gauge",
         "targets": [
           {
             "expr": "keeper_slo_poll_freshness_rate",
             "legendFormat": "Freshness SLO"
           }
         ],
         "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 }
       },
       {
         "id": 12,
         "title": "Execution Timeliness SLO Rate",
         "type": "gauge",
         "targets": [
           {
             "expr": "keeper_slo_execution_timeliness_rate",
             "legendFormat": "Timeliness SLO"
           }
         ],
         "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 }
       },
       {
         "id": 13,
         "title": "Retry Queue Size",
         "type": "stat",
         "targets": [
           {
             "expr": "keeper_retry_queue_size",
             "legendFormat": "Queued"
           }
         ],
         "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 }
       },
       {
         "id": 14,
         "title": "Oldest Task Age (seconds)",
         "type": "stat",
         "targets": [
           {
             "expr": "keeper_oldest_task_age_seconds",
             "legendFormat": "Age (s)"
           }
         ],
         "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 }
       },
       {
         "id": 15,
         "title": "Task Execution Lateness (ledgers)",
         "type": "graph",
         "targets": [
           {
             "expr": "histogram_quantile(0.95, rate(keeper_task_execution_lateness_ledgers_bucket[5m]))",
             "legendFormat": "p95"
           },
           {
             "expr": "histogram_quantile(0.50, rate(keeper_task_execution_lateness_ledgers_bucket[5m]))",
             "legendFormat": "p50"
           }
         ],
         "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 }
       },
       {
         "id": 16,
         "title": "Retry Attempts",
         "type": "graph",
         "targets": [
           {
             "expr": "rate(keeper_retry_attempts_total{outcome=\"success\"}[5m])",
             "legendFormat": "Success"
           },
           {
             "expr": "rate(keeper_retry_attempts_total{outcome=\"failure\"}[5m])",
             "legendFormat": "Failure"
           },
           {
             "expr": "rate(keeper_retry_attempts_total{outcome=\"duplicate\"}[5m])",
             "legendFormat": "Duplicate"
           }
         ],
         "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 }
       }
     ],
     "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
