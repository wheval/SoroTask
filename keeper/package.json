{
  "name": "keeper",
  "version": "1.0.0",
  "description": "SoroTask Keeper - Production-grade task execution service for Soroban smart contracts",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js | pino-pretty",
    "dry-run": "node index.js --dry-run",
    "mock-rpc": "node mock-rpc.js",
    "test": "jest",
    "test:e2e": "node __tests__/e2e-run.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:coverage": "jest --coverage",
    "test:chaos": "jest chaos.test.js",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "docker:build": "docker build -t sorotask-keeper .",
    "docker:run": "docker run --env-file .env -p 3000:3000 -v $(pwd)/data:/app/data sorotask-keeper",
    "bench": "node benchmarks/poller.bench.js && node benchmarks/executor.bench.js",
    "bench:poller": "node benchmarks/poller.bench.js",
    "bench:executor": "node benchmarks/executor.bench.js",
    "bench:compare": "node benchmarks/compare.js",
    "chaos-test": "node scripts/chaos-test.js run",
    "chaos-test:list": "node scripts/chaos-test.js list",
    "chaos-test:single": "node scripts/chaos-test.js single"
  },
  "keywords": [
    "soroban",
    "stellar",
    "keeper",
    "automation",
    "smart-contracts"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stellar/stellar-sdk": "^15.1.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "which-typed-array": "^1.1.20"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-jest": "^30.4.1",
    "benny": "^3.7.1",
    "eslint": "^10.4.1",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3"
  }
}
